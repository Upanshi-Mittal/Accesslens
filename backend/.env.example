# backend/.env

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Browser Settings
BROWSER_HEADLESS=false
BROWSER_MAX_PAGES=3
BROWSER_TIMEOUT=60000

# Audit Settings
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
MAX_AUDIT_DURATION=600

# Engine Settings
ENABLED_ENGINES=["wcag_deterministic","contrast_engine","structural_engine","ai_engine"]

# AI Model Paths
LLAVA_MODEL_PATH=./models/llava
MISTRAL_MODEL_PATH=./models/mistral-7b

# AI Settings
AI_USE_LOCAL=true
AI_CONFIDENCE_THRESHOLD=0.7
LLAVA_ENDPOINT=http://localhost:8001
MISTRAL_ENDPOINT=http://localhost:8002

# Database (SQLite — no external server needed)
DATABASE_URL=sqlite:///./accesslens.db

# Redis (optional — comment out to disable; cache falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PATH=./data

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=./logs/accesslens.log
JSON_LOGS=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001