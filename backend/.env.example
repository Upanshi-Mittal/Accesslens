# backend/.env.example
# AccessLens Backend Configuration
# Copy this file to .env and modify as needed

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Browser Settings
BROWSER_HEADLESS=true
BROWSER_MAX_PAGES=5
BROWSER_TIMEOUT=30000

# Audit Settings
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
MAX_AUDIT_DURATION=300

# Engine Settings
ENABLED_ENGINES=["wcag_deterministic","contrast_engine","structural_engine","ai_engine"]

# AI Model Paths
LLAVA_MODEL_PATH=/app/models/llava
MISTRAL_MODEL_PATH=/app/models/mistral-7b

# AI Settings
AI_USE_LOCAL=true
AI_CONFIDENCE_THRESHOLD=0.7
LLAVA_ENDPOINT=http://llava:8001
MISTRAL_ENDPOINT=http://mistral:8002

# Database (PostgreSQL)
DATABASE_URL=postgresql://accesslens:accesslens@localhost:5432/accesslens

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PATH=./data

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/accesslens.log
JSON_LOGS=true

# CORS
CORS_ORIGINS=http://localhost:3000

# API Keys (for cloud AI services, if not using local)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=