# backend/.coveragerc
[run]
source = app
omit = 
    tests/*
    scripts/*
    migrations/*
    app/__init__.py
    app/main.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
    
fail_under = 50
show_missing = True

[html]
directory = coverage_html